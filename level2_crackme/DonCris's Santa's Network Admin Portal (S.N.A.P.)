def ror(v, s):
    v &= 0xFFFFFFFF
    s %= 32
    return ((v >> s) | (v << (32 - s))) & 0xFFFFFFFF

def gen(u):
    h = 0xCAFEBABE
    for c in u:
        c = ord(c) & 0xFF
        h = ror(h ^ c, (c % 7) + 1)
        h = ((h + 0x5AA55AA5) & 0xFFFFFFFF)
        h ^= (h << 4) & 0xFFFFFFFF
        h &= 0xFFFFFFFF
    return h ^ 0xDEADBEEF

