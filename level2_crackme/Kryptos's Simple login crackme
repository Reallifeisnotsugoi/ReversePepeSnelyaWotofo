import ctypes

def generate_password(username):
    v4 = ctypes.c_int32(0) 
    
    for i, char in enumerate(username):
        c = ord(char)      # Берем ASCII код символа
        index = i + 1      # Индекс умножения (начинается с 1)
        
        # v9 = v4 + c * (i + 1)
        v9 = ctypes.c_int32(v4.value + (c * index))
        
        # v4 = (v9 * 8) ^ v9
        v4 = ctypes.c_int32(v9.value ^ (8 * v9.value))
        
    # imul edx, r8d, 539h
    final_hash = ctypes.c_int32(v4.value * 0x539) # 0x539 = 1337 в десятичной
    
    # xor edx, 5A5Ah
    final_hash = ctypes.c_int32(final_hash.value ^ 0x5A5A) # 0x5A5A = 23130 в десятичной
    
    signed_pass = str(final_hash.value)
    unsigned_pass = str(ctypes.c_uint32(final_hash.value).value)
    
    return signed_pass, unsigned_pass

